[
  {
    "$schema": "https://raw.githubusercontent.com/memizy/oqse-specification/main/schemas/manifest/v0.json",
    "version": "0.1.0",
    "id": "multiplayer-quiz",
    "appName": "Multiplayer Quiz",
    "description": "Kahoot-style multiplayer quiz with live leaderboard.",
    "author": "Memizy Team",
    "url": "/plugins/multiplayer-quiz/index.html",
    "capabilities": {
      "types": ["mcq-single", "mcq-multi", "true-false", "short-answer", "match-pairs"]
    },
    "settings": [
      { "key": "timePerQuestion", "label": "Time per question (seconds)", "type": "number", "default": 20, "min": 5, "max": 120 },
      { "key": "shuffleQuestions", "label": "Shuffle question order", "type": "boolean", "default": false }
    ]
  }
]
